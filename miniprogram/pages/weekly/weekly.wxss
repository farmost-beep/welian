/* pages/weekly/weekly.wxss */

.header {
  margin-bottom: 32rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

/* ── 周报分区 ── */
.section-card {
  margin-bottom: 24rpx;
}

.section-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.weekly-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.item-dot {
  font-size: 36rpx;
  line-height: 1.4;
  color: #6B6860;
  flex-shrink: 0;
}

.item-dot.leverage { color: #C96442; }
.item-dot.nurture  { color: #4A7C59; }

.item-content {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
}

.item-reason {
  font-size: 26rpx;
}

.item-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1A1915;
  flex: 1;
}
