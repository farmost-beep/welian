/* pages/article/article.wxss — 原文阅读页 */
.article-page {
  padding: 24rpx 32rpx 80rpx;
  min-height: 100vh;
  background: #FAFAF7;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 20rpx;
}
.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #D9D5C7;
  border-top-color: #4A6741;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 错误/不支持 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  gap: 16rpx;
}
.error-icon { font-size: 64rpx; }
.error-text { font-size: 28rpx; color: #6B6860; text-align: center; }
.error-actions { margin-top: 24rpx; width: 100%; }

/* 文章标题 */
.article-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1915;
  line-height: 1.4;
  margin-bottom: 24rpx;
}

/* rich-text 内容样式（通过外层 class 控制） */
.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #1A1915;
}

/* 底部复制链接 */
.article-footer {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid #D9D5C7;
  display: flex;
  justify-content: center;
}
.copy-link-btn {
  padding: 16rpx 40rpx;
  background: #EDEBE3;
  border: 1rpx solid #D9D5C7;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #6B6860;
}
.copy-link-btn:active {
  background: #D9D5C7;
}
