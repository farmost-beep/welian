/* pages/mine/mine.wxss */

.brand-header {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: #1A1915;
}

.brand-inf {
  font-size: 44rpx;
  color: #C96442;
}

.brand-tagline {
  font-size: 26rpx;
  margin-bottom: 32rpx;
  display: block;
}

/* ── 套餐卡片 ── */
.plan-card {
  margin-bottom: 32rpx;
}

.plan-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-label {
  font-size: 28rpx;
  color: #6B6860;
}

.plan-credits {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A7C59;
}

/* ── 绑定卡片 ── */
.bind-card {
  margin-bottom: 32rpx;
  padding: 24rpx 28rpx;
}
.bind-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1915;
}
.bind-input {
  border: 1rpx solid #D9D5C7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  background: #F5F4EE;
}

/* ── 菜单 ── */
.menu-group {
  background: #EDEBE3;
  border: 1rpx solid #D9D5C7;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #D9D5C7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1A1915;
}

.menu-arrow {
  font-size: 36rpx;
}

/* ── 关于 ── */
.about {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 0;
}

/* ── 注册成功庆祝动画 ── */
.celebration-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 25, 21, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.celebration-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.celebration-icon-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.celebration-check {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #4A6741;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #FAFAF7;
  font-weight: 700;
  animation: checkPop 0.4s ease 0.1s both;
}

.spark {
  position: absolute;
  font-size: 32rpx;
  animation: sparkFly 1s ease-out 0.3s both;
}
.spark-1 { top: 0; left: -20rpx; animation-delay: 0.3s; }
.spark-2 { top: -10rpx; right: -10rpx; animation-delay: 0.4s; }
.spark-3 { bottom: 0; left: 10rpx; animation-delay: 0.5s; }
.spark-4 { bottom: -10rpx; right: -20rpx; animation-delay: 0.6s; }

.celebration-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FAFAF7;
  margin-bottom: 12rpx;
}

.celebration-subtitle {
  font-size: 26rpx;
  color: #C4BFB3;
  text-align: center;
  line-height: 1.5;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes popIn {
  from { transform: scale(0.5); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

@keyframes checkPop {
  from { transform: scale(0); }
  to { transform: scale(1); }
}

@keyframes sparkFly {
  0% { transform: scale(0) translate(0, 0); opacity: 0; }
  50% { transform: scale(1.2) translate(10rpx, -20rpx); opacity: 1; }
  100% { transform: scale(0.8) translate(30rpx, -60rpx); opacity: 0; }
}
