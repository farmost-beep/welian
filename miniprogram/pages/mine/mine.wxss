/* pages/mine/mine.wxss */

.brand-header {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: #1A1915;
}

.brand-inf {
  font-size: 44rpx;
  color: #C96442;
}

.brand-tagline {
  font-size: 26rpx;
  margin-bottom: 32rpx;
  display: block;
}

/* ── 套餐卡片 ── */
.plan-card {
  margin-bottom: 32rpx;
}

.plan-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-label {
  font-size: 28rpx;
  color: #6B6860;
}

.plan-credits {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A7C59;
}

/* ── 绑定卡片 ── */
.bind-card {
  margin-bottom: 32rpx;
  padding: 24rpx 28rpx;
}
.bind-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1915;
}
.bind-input {
  border: 1rpx solid #D9D5C7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  background: #F5F4EE;
}

/* ── 菜单 ── */
.menu-group {
  background: #EDEBE3;
  border: 1rpx solid #D9D5C7;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #D9D5C7;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1A1915;
}

.menu-arrow {
  font-size: 36rpx;
}

/* ── 关于 ── */
.about {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 40rpx 0;
}
