<!-- pages/mine/mine.wxml — 我的 -->
<view class="container">
  <!-- 品牌头 -->
  <view class="brand-header">
    <text class="brand-name">Welian</text>
    <text class="brand-inf">∞</text>
  </view>
  <text class="brand-tagline text-dim">更用心 — 更好的朋友、更好的家人、更好的合作者</text>

  <!-- 当前套餐 -->
  <view class="card plan-card">
    <view class="plan-row">
      <text class="plan-label">当前套餐</text>
      <text class="tag tag-{{plan === 'pro' ? 'leverage' : 'dual'}}">{{planLabel}}</text>
    </view>
    <view class="plan-row">
      <text class="plan-label">剩余额度</text>
      <text class="plan-credits">{{credits}} 点</text>
    </view>
    <button class="btn btn-block" bindtap="goBilling">管理套餐 / 充值</button>
  </view>

  <!-- 账号绑定 -->
  <view wx:if="{{!isBound && openid}}" class="card bind-card">
    <text class="bind-title">🔗 绑定 / 注册 Web 账号</text>
    <text class="text-dim text-sm" style="display:block;margin:6px 0 10px">输入邮箱验证后同步数据。新邮箱将自动注册。</text>
    <input
      class="bind-input"
      type="text"
      placeholder="你的注册邮箱"
      value="{{bindEmail}}"
      bindinput="onBindEmailInput"
    />
    <button wx:if="{{!codeSent}}" class="btn btn-block" style="margin-top:10px" bindtap="sendCode" loading="{{sendingCode}}">发送验证码</button>
    <block wx:if="{{codeSent}}">
      <input
        class="bind-input"
        type="number"
        placeholder="6位验证码"
        value="{{bindCode}}"
        bindinput="onBindCodeInput"
        maxlength="6"
        style="margin-top:10px"
      />
      <button class="btn btn-block" style="margin-top:10px" bindtap="verifyAndBind" loading="{{binding}}">绑定</button>
    </block>
    <text wx:if="{{bindMsg}}" class="text-sm {{bindMsg === '绑定中…' || bindMsg === '发送中…' || bindMsg === '验证码已发到邮箱，请查收' ? 'text-dim' : 'text-accent'}}" style="display:block;margin-top:8px">{{bindMsg}}</text>
  </view>

  <view wx:if="{{isBound}}" class="card" style="padding:12px 16px">
    <view style="display:flex;justify-content:space-between;align-items:center">
      <text class="text-green text-sm">✓ 已绑定 Web 账号，数据已同步</text>
      <text class="text-accent text-sm" style="text-decoration:underline" bindtap="unbind">解绑</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goWeekly">
      <text class="menu-icon">📋</text>
      <text class="menu-text">周报</text>
      <text class="menu-arrow text-dimmer">›</text>
    </view>
    <view class="menu-item" bindtap="goBilling">
      <text class="menu-icon">💳</text>
      <text class="menu-text">充值 / 套餐</text>
      <text class="menu-arrow text-dimmer">›</text>
    </view>
  </view>

  <!-- 关于 -->
  <view class="about">
    <text class="text-dimmer text-xs">维联 — 维系情感，联结目标</text>
    <text class="text-dimmer text-xs">© 2026 Welian ∞</text>
  </view>
</view>

<!-- 注册成功庆祝动画 -->
<view wx:if="{{showCelebration}}" class="celebration-overlay" catchtap="dismissCelebration">
  <view class="celebration-content">
    <view class="celebration-icon-wrap">
      <view class="celebration-check">✓</view>
      <view class="spark spark-1">✨</view>
      <view class="spark spark-2">🎉</view>
      <view class="spark spark-3">🌱</view>
      <view class="spark spark-4">✨</view>
    </view>
    <text class="celebration-title">注册成功！</text>
    <text class="celebration-subtitle text-dim">欢迎加入 Welian，开始用心经营你的关系网络</text>
  </view>
</view>
