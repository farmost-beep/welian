<!-- pages/contact-detail/contact-detail.wxml -->
<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text class="text-dimmer text-sm">加载中…</text>
  </view>

  <view wx:if="{{error && !loading}}" class="loading">
    <text class="text-accent text-sm">{{error}}</text>
  </view>

  <block wx:if="{{contact && !loading}}">
    <!-- 联系人头部 -->
    <view class="card contact-header">
      <view class="contact-name-row">
        <text class="contact-name-lg">{{contact.name}}</text>
        <text class="tag tag-{{contact.nature === 'leverage' ? 'leverage' : (contact.nature === 'nurture' ? 'nurture' : 'dual')}}">{{contact.nature === 'leverage' ? '撬动' : (contact.nature === 'nurture' ? '维系' : '双重')}}</text>
      </view>
      <view wx:if="{{contact.company}}" class="info-row">
        <text class="text-dim text-sm">{{contact.company}}</text>
      </view>
      <view wx:if="{{contact.title || contact.role}}" class="info-row">
        <text class="text-dim text-sm">{{contact.title || contact.role}}</text>
      </view>
      <view wx:if="{{contact.relation || contact.relationship}}" class="info-row">
        <text class="text-dim text-sm">关系：{{contact.relation || contact.relationship}}</text>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="action-bar">
      <button class="action-btn" bindtap="recordInteraction">📝 记录互动</button>
      <button class="action-btn" bindtap="draftMessage">✍️ 拟写消息</button>
    </view>

    <!-- 联系信息 -->
    <view wx:if="{{contact.phone || contact.email || contact.wechat}}" class="card">
      <view class="section-title-sm">联系方式</view>
      <view wx:if="{{contact.phone}}" class="info-row">
        <text class="text-dim text-sm">电话：{{contact.phone}}</text>
      </view>
      <view wx:if="{{contact.email}}" class="info-row">
        <text class="text-dim text-sm">邮箱：{{contact.email}}</text>
      </view>
      <view wx:if="{{contact.wechat}}" class="info-row">
        <text class="text-dim text-sm">微信：{{contact.wechat}}</text>
      </view>
    </view>

    <!-- 重要日期 -->
    <view wx:if="{{contact.birthday}}" class="card">
      <view class="section-title-sm">重要日期</view>
      <view class="info-row">
        <text class="text-accent text-sm">🎂 生日：{{contact.birthday}}</text>
      </view>
    </view>

    <!-- 备注 -->
    <view wx:if="{{contact.notes}}" class="card">
      <view class="section-title-sm">备注</view>
      <text class="text-dim text-sm">{{contact.notes}}</text>
    </view>

    <!-- 互动历史 -->
    <view class="card">
      <view class="section-title-sm">最近互动</view>
      <view wx:if="{{timeline.length === 0}}" class="empty-state">
        <text class="text-dimmer text-sm">暂无互动记录</text>
      </view>
      <view wx:for="{{timeline}}" wx:key="id" class="timeline-item">
        <text class="text-sm">{{item.summary}}</text>
        <text class="text-dimmer text-xs">{{item.date}}</text>
      </view>
    </view>

    <!-- 编辑/删除操作 -->
    <view class="action-bar" style="margin-top:16px">
      <button class="action-btn" bindtap="editContact">✏️ 编辑</button>
      <button class="action-btn action-btn-danger" bindtap="deleteContact">🗑️ 删除</button>
    </view>
  </block>
</view>

<!-- 编辑联系人弹窗 -->
<view wx:if="{{showEdit}}" class="edit-overlay" catchtap="closeEdit">
  <view class="edit-modal" catchtap="">
    <view class="edit-title">编辑联系人</view>
    <view class="edit-field">
      <text class="edit-label">姓名</text>
      <input class="edit-input" value="{{editForm.name}}" bindinput="onEditInput" data-field="name" placeholder="姓名" />
    </view>
    <view class="edit-field">
      <text class="edit-label">公司</text>
      <input class="edit-input" value="{{editForm.company}}" bindinput="onEditInput" data-field="company" placeholder="公司" />
    </view>
    <view class="edit-field">
      <text class="edit-label">职位</text>
      <input class="edit-input" value="{{editForm.title}}" bindinput="onEditInput" data-field="title" placeholder="职位" />
    </view>
    <view class="edit-field">
      <text class="edit-label">关系类型</text>
      <picker mode="selector" range="{{natureOptions}}" value="{{natureIndex}}" bindchange="onNatureChange">
        <view class="edit-input">{{natureOptions[natureIndex]}}</view>
      </picker>
    </view>
    <view class="edit-field">
      <text class="edit-label">关系说明</text>
      <input class="edit-input" value="{{editForm.relation}}" bindinput="onEditInput" data-field="relation" placeholder="如：前同事、行业前辈" />
    </view>
    <view class="edit-field">
      <text class="edit-label">电话</text>
      <input class="edit-input" value="{{editForm.phone}}" bindinput="onEditInput" data-field="phone" placeholder="电话" />
    </view>
    <view class="edit-field">
      <text class="edit-label">邮箱</text>
      <input class="edit-input" value="{{editForm.email}}" bindinput="onEditInput" data-field="email" placeholder="邮箱" />
    </view>
    <view class="edit-field">
      <text class="edit-label">生日</text>
      <input class="edit-input" value="{{editForm.birthday}}" bindinput="onEditInput" data-field="birthday" placeholder="如：1990-03-15" />
    </view>
    <view class="edit-field">
      <text class="edit-label">备注</text>
      <textarea class="edit-input edit-textarea" value="{{editForm.notes}}" bindinput="onEditInput" data-field="notes" placeholder="备注" />
    </view>
    <view class="edit-actions">
      <button class="action-btn" bindtap="closeEdit">取消</button>
      <button class="action-btn action-btn-primary" bindtap="saveEdit" loading="{{savingEdit}}">保存</button>
    </view>
  </view>
</view>
