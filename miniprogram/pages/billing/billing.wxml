<!-- pages/billing/billing.wxml — 充值页 -->
<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="page-title">套餐与额度</text>
    <text class="page-subtitle">数据归你，智能来云</text>
  </view>

  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="text-dimmer text-sm">加载中…</text>
  </view>

  <block wx:if="{{!loading}}">
    <!-- 当前状态 -->
    <view class="card status-card">
      <view class="status-row">
        <text class="status-label">当前套餐</text>
        <text class="tag tag-{{plan === 'pro' ? 'leverage' : 'dual'}}">{{planLabel}}</text>
      </view>
      <view class="status-row">
        <text class="status-label">剩余额度</text>
        <text class="status-credits">{{credits}} / {{creditsTotal}} 点</text>
      </view>
      <!-- 额度进度条 -->
      <view class="credits-bar">
        <view class="credits-fill" style="width: {{credits / creditsTotal * 100}}%"></view>
      </view>
      <text class="text-dimmer text-xs">额度将于 {{creditsResetAt}} 重置</text>
    </view>

    <!-- 套餐选择 -->
    <view class="plans-section">
      <text class="section-title">选择套餐</text>

      <view wx:for="{{plans}}" wx:key="key" class="card plan-option {{item.current ? 'current' : ''}}">
        <view class="plan-header">
          <view class="plan-title-group">
            <text class="plan-name">{{item.name}}</text>
            <text wx:if="{{item.current}}" class="tag tag-leverage">当前</text>
          </view>
          <view class="plan-price-group">
            <text class="plan-price">¥{{item.price}}</text>
            <text class="plan-period text-dimmer text-xs">/月</text>
          </view>
        </view>

        <view class="plan-credits-row">
          <text class="text-green text-sm">{{item.credits}} {{item.unit}}</text>
        </view>

        <view class="plan-features">
          <text wx:for="{{item.features}}" wx:for-item="feat" wx:key="index" class="feature-item">
            <text class="feature-check text-green">✓</text>
            <text class="feature-text text-sm">{{feat}}</text>
          </text>
        </view>

        <button
          wx:if="{{!item.current}}"
          class="btn btn-block"
          bindtap="upgrade"
          data-key="{{item.key}}"
        >
          {{item.key === 'pro' ? '升级到 Pro' : '切换到 Free'}}
        </button>
        <view wx:else class="current-badge">
          <text class="text-dim text-sm">当前使用中</text>
        </view>
      </view>
    </view>

    <!-- 说明 -->
    <view class="billing-note">
      <text class="text-dimmer text-xs">· 记录功能永久免费，不限额度</text>
    </view>
    <view class="billing-note">
      <text class="text-dimmer text-xs">· AI 点数用于智能拟稿、建议引擎等云端功能</text>
    </view>
    <view class="billing-note">
      <text class="text-dimmer text-xs">· 数据支持一键导出/迁移，不锁定用户</text>
    </view>
  </block>
</view>
