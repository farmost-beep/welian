/* pages/billing/billing.wxss */

.header {
  margin-bottom: 32rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

/* ── 当前状态 ── */
.status-card {
  margin-bottom: 32rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-label {
  font-size: 28rpx;
  color: #6B6860;
}

.status-credits {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A7C59;
}

/* ── 额度进度条 ── */
.credits-bar {
  height: 12rpx;
  background: #E4E1D6;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.credits-fill {
  height: 100%;
  background: #4A7C59;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* ── 套餐选择 ── */
.plans-section {
  margin-bottom: 24rpx;
}

.plan-option {
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.plan-option.current {
  border-color: #4A7C59;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.plan-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plan-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1915;
}

.plan-price-group {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.plan-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #C96442;
}

.plan-period {
  margin-left: 2rpx;
}

.plan-credits-row {
  margin-bottom: 20rpx;
}

/* ── 功能列表 ── */
.plan-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-check {
  font-size: 28rpx;
  font-weight: 600;
}

.feature-text {
  color: #1A1915;
}

/* ── 当前套餐标记 ── */
.current-badge {
  text-align: center;
  padding: 20rpx 0;
}

/* ── 说明 ── */
.billing-note {
  padding: 6rpx 0;
}

/* ── 额度详情 ── */
.credits-detail {
  display: flex;
  align-items: center;
  gap: 32rpx;
  margin-bottom: 20rpx;
}
.credits-main {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.credits-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #4A7C59;
  line-height: 1;
}
.credits-unit { margin-top: 6rpx; }
.credits-breakdown {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.breakdown-row {
  display: flex;
  justify-content: space-between;
}

/* ── 订阅信息 ── */
.subscription-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E4E1D6;
}

/* ── 升级卡片 ── */
.upgrade-card { margin-bottom: 24rpx; }
.plan-options { margin-top: 12rpx; }
.plan-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}
.plan-option-info { display: flex; flex-direction: column; gap: 4rpx; }
.plan-option-name { font-size: 30rpx; font-weight: 600; color: #1A1915; }
.plan-option-arrow { font-size: 36rpx; }

/* ── 加油包 ── */
.pack-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #E4E1D6;
}
.pack-option:last-child { border-bottom: none; }
.pack-info { display: flex; flex-direction: column; gap: 4rpx; }
.pack-name { font-size: 30rpx; font-weight: 600; color: #1A1915; }
.pack-btn {
  font-size: 26rpx;
  color: #C96442;
  padding: 10rpx 28rpx;
  background: #EDEBE3;
  border-radius: 10rpx;
}

/* ── 优惠券 ── */
.coupon-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}
.coupon-input {
  flex: 1;
  border: 1rpx solid #D9D5C7;
  border-radius: 10rpx;
  padding: 14rpx 18rpx;
  font-size: 28rpx;
  background: #F5F4EE;
}
.coupon-btn {
  font-size: 26rpx;
  padding: 0 28rpx;
  background: #4A6741;
  color: #FAFAF7;
  border: none;
  border-radius: 10rpx;
  line-height: 64rpx;
}
.coupon-btn::after { border: none; }

/* ── 赠予 ── */
.gift-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ── 用量历史 ── */
.history-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E4E1D6;
}
.history-item:last-child { border-bottom: none; }
.history-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 4rpx;
}
.empty-state { text-align: center; padding: 30rpx 0; }
