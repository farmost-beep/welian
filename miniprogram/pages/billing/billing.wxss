/* pages/billing/billing.wxss */

.header {
  margin-bottom: 32rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

/* ── 当前状态 ── */
.status-card {
  margin-bottom: 32rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-label {
  font-size: 28rpx;
  color: #6B6860;
}

.status-credits {
  font-size: 32rpx;
  font-weight: 600;
  color: #4A7C59;
}

/* ── 额度进度条 ── */
.credits-bar {
  height: 12rpx;
  background: #E4E1D6;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.credits-fill {
  height: 100%;
  background: #4A7C59;
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* ── 套餐选择 ── */
.plans-section {
  margin-bottom: 24rpx;
}

.plan-option {
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.plan-option.current {
  border-color: #4A7C59;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.plan-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.plan-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1915;
}

.plan-price-group {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.plan-price {
  font-size: 40rpx;
  font-weight: 600;
  color: #C96442;
}

.plan-period {
  margin-left: 2rpx;
}

.plan-credits-row {
  margin-bottom: 20rpx;
}

/* ── 功能列表 ── */
.plan-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.feature-check {
  font-size: 28rpx;
  font-weight: 600;
}

.feature-text {
  color: #1A1915;
}

/* ── 当前套餐标记 ── */
.current-badge {
  text-align: center;
  padding: 20rpx 0;
}

/* ── 说明 ── */
.billing-note {
  padding: 6rpx 0;
}
