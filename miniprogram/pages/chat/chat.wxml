<!-- pages/chat/chat.wxml — 小维 AI 对话 -->
<view class="chat-container">
  <!-- 顶部状态栏 -->
  <view class="chat-header">
    <text class="chat-title">小维</text>
    <view class="chat-status">
      <view class="status-dot {{connected ? 'online' : 'offline'}}"></view>
      <text class="status-text text-dimmer text-xs">{{connected ? '在线' : '连接中…'}}</text>
    </view>
    <view class="clear-btn" bindtap="clearHistory">
      <text class="text-dimmer text-xs">清空</text>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollIntoView}}"
    scroll-with-animation
    enhanced
    show-scrollbar="{{false}}"
  >
    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="message-row {{item.role === 'user' ? 'message-user' : 'message-assistant'}}">
      <!-- AI 头像 -->
      <view wx:if="{{item.role === 'assistant'}}" class="avatar">
        <text class="avatar-text">维</text>
      </view>
      <!-- 消息气泡 -->
      <view class="bubble {{item.role === 'user' ? 'bubble-user' : 'bubble-assistant'}}">
        <text class="bubble-text">{{item.content}}</text>
        <view wx:if="{{item.streaming && !item.content}}" class="typing-indicator">
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
          <view class="typing-dot"></view>
        </view>
      </view>
    </view>
    <view id="msg-bottom" class="scroll-anchor"></view>
  </scroll-view>

  <!-- 错误提示 -->
  <view wx:if="{{error}}" class="error-bar">
    <text class="error-text text-accent text-xs">{{error}}</text>
  </view>

  <!-- 输入区 -->
  <view class="input-bar">
    <textarea
      class="chat-input"
      placeholder="和小维说点什么…"
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="onConfirm"
      confirm-type="send"
      auto-height
      maxlength="-1"
      disabled="{{sending}}"
      adjust-position
    />
    <view
      class="send-btn {{(inputText && !sending) ? 'send-active' : 'send-disabled'}}"
      bindtap="sendMessage"
    >
      <text class="send-text">{{sending ? '…' : '发送'}}</text>
    </view>
  </view>
</view>
