/* pages/chat/chat.wxss — 小维 AI 对话 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F4EE;
}

/* ── 顶部状态栏 ── */
.chat-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #EDEBE3;
  border-bottom: 1rpx solid #D9D5C7;
}
.chat-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1915;
}
.chat-status {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
  gap: 6rpx;
}
.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}
.status-dot.online { background: #4A6741; }
.status-dot.offline { background: #C4BFB3; }
.clear-btn {
  margin-left: auto;
  padding: 8rpx 16rpx;
}

/* ── 消息列表 ── */
.message-list {
  flex: 1;
  padding: 24rpx 20rpx;
  overflow-y: auto;
}
.scroll-anchor { height: 1rpx; }

.message-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}
.message-user {
  flex-direction: row-reverse;
}

/* ── 头像 ── */
.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #4A6741;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.avatar-text {
  color: #FAFAF7;
  font-size: 28rpx;
  font-weight: 600;
}

/* ── 消息气泡 ── */
.bubble {
  max-width: 75%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  word-break: break-word;
}
.bubble-assistant {
  background: #FFFFFF;
  border: 1rpx solid #E8E5DC;
  border-top-left-radius: 6rpx;
}
.bubble-user {
  background: #4A6741;
  border-top-right-radius: 6rpx;
  margin-left: auto;
}
.bubble-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1A1915;
  white-space: pre-wrap;
}
.bubble-user .bubble-text {
  color: #FAFAF7;
}

/* ── 打字指示器 ── */
.typing-indicator {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0;
}
.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C4BFB3;
  animation: typing 1.4s infinite ease-in-out;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
  0%, 60%, 100% { transform: scale(0.8); opacity: 0.5; }
  30% { transform: scale(1.2); opacity: 1; }
}

/* ── 错误提示 ── */
.error-bar {
  padding: 12rpx 24rpx;
  background: #FFF5F0;
  border-top: 1rpx solid #E8D5CC;
}

/* ── 输入区 ── */
.input-bar {
  display: flex;
  align-items: flex-end;
  padding: 16rpx 20rpx;
  background: #EDEBE3;
  border-top: 1rpx solid #D9D5C7;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.chat-input {
  flex: 1;
  min-height: 64rpx;
  max-height: 200rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #D9D5C7;
}
.send-btn {
  margin-left: 16rpx;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}
.send-active {
  background: #4A6741;
}
.send-disabled {
  background: #C4BFB3;
}
.send-text {
  color: #FAFAF7;
  font-size: 28rpx;
  font-weight: 500;
}
