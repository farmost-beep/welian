/* pages/dashboard/dashboard.wxss */

.header {
  margin-bottom: 32rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

/* ── 角色卡片 ── */
.role-card {
  margin-bottom: 24rpx;
}

.role-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.role-icon {
  font-size: 40rpx;
}

.role-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1915;
}

/* ── 行为条目 ── */
.role-items {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.role-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.item-dot {
  font-size: 36rpx;
  line-height: 1.4;
  color: #6B6860;
  flex-shrink: 0;
}

.item-dot.positive { color: #4A7C59; }
.item-dot.warning  { color: #C96442; }

.item-text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #1A1915;
  flex: 1;
}

/* ── 底部 ── */
.footer-note {
  text-align: center;
  padding: 40rpx 20rpx;
  line-height: 1.8;
}
