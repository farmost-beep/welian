<!-- pages/dashboard/dashboard.wxml — 角色仪表盘 -->
<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="page-title">📊 {{month}}的你</text>
    <text class="page-subtitle">更好的朋友、更好的家人、更好的合作者</text>
  </view>

  <!-- 加载态 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="text-dimmer text-sm">正在回顾你本月的故事…</text>
  </view>

  <!-- 错误态 -->
  <view wx:if="{{error && !loading}}" class="loading">
    <text class="text-accent text-sm">{{error}}</text>
    <view style="margin-top:12px"><button size="mini" bindtap="loadDashboard">重试</button></view>
  </view>

  <block wx:if="{{!loading && !error}}">
    <!-- 统计概览 -->
    <view wx:if="{{!isEmpty}}" class="stats-bar">
      <view class="stat-item">
        <text class="stat-num">{{stats.total}}</text>
        <text class="stat-label text-dimmer text-xs">联系人</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.leverage}}</text>
        <text class="stat-label text-dimmer text-xs">经营型</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.nurture}}</text>
        <text class="stat-label text-dimmer text-xs">陪伴型</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.dual}}</text>
        <text class="stat-label text-dimmer text-xs">双重型</text>
      </view>
    </view>

    <!-- 新用户引导 -->
    <view wx:if="{{isEmpty}}" class="card empty-guide">
      <text class="text-accent" style="font-size:16px;font-weight:600">还没有联系人数据</text>
      <text class="text-dim text-sm" style="margin-top:8px;display:block">去「关系」页添加几个重要的人，开始记录你们的互动，仪表盘就会显示你的月度行为回顾。</text>
      <button class="btn btn-block" style="margin-top:12px" bindtap="goContacts">去添加联系人</button>
    </view>

    <!-- 三角色分栏 -->
    <block wx:for="{{roles}}" wx:key="key">
      <view class="card role-card">
        <view class="role-header">
          <text class="role-icon">{{item.icon}}</text>
          <text class="role-label">{{item.label}}</text>
        </view>
        <view class="role-items">
          <view wx:for="{{item.items}}" wx:for-item="entry" wx:key="index" class="role-item">
            <text class="item-dot {{entry.tone}}">·</text>
            <text class="item-text {{entry.tone === 'warning' ? 'text-accent' : ''}} {{entry.tone === 'positive' ? 'text-green' : ''}}">{{entry.text}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- 底部说明 -->
    <view class="footer-note">
      <text class="text-dimmer text-xs">Welian 只做行为回顾，不做评分。这个月过得怎么样，由你判断。</text>
    </view>
  </block>
</view>
