/* app.wxss — 全局样式，对齐 Web 端暖色调 */

page {
  background: #F5F4EE;
  color: #1A1915;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ── 色彩变量（供页面参考，小程序不支持 CSS 变量在 wxss 中全局生效，此处仅注释参考） ── */
/* bg=#F5F4EE  surface=#EDEBE3  surface2=#E4E1D6  border=#D9D5C7 */
/* text=#1A1915  dim=#6B6860  dimmer=#9A968C */
/* accent=#C96442  accentBg=#F2E8E0  green=#4A7C59 */

/* ── 通用容器 ── */
.container {
  padding: 32rpx 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* ── 卡片 ── */
.card {
  background: #EDEBE3;
  border: 1rpx solid #D9D5C7;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

/* ── 标题 ── */
.page-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1A1915;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #6B6860;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1915;
  margin-bottom: 16rpx;
}

/* ── 文字工具 ── */
.text-dim { color: #6B6860; }
.text-dimmer { color: #9A968C; }
.text-accent { color: #C96442; }
.text-green { color: #4A7C59; }
.text-sm { font-size: 24rpx; }
.text-xs { font-size: 22rpx; }

/* ── 按钮 ── */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #C96442;
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn::after { border: none; }

.btn-secondary {
  background: #EDEBE3;
  color: #1A1915;
  border: 1rpx solid #D9D5C7;
}

.btn-block {
  display: flex;
  width: 100%;
}

/* ── 标签 ── */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.tag-leverage {
  background: #F2E8E0;
  color: #C96442;
}

.tag-nurture {
  background: rgba(74, 124, 89, 0.12);
  color: #4A7C59;
}

.tag-dual {
  background: #E4E1D6;
  color: #6B6860;
}

/* ── 分割线 ── */
.divider {
  height: 1rpx;
  background: #D9D5C7;
  margin: 24rpx 0;
}
